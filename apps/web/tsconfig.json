{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "strict": true,
    "jsx": "preserve",
    "skipLibCheck": true,
    "paths": {
      "@landmap/api": [
        "../../packages/api/src/index.ts"
      ],
      "@landmap/api/*": [
        "../../packages/api/src/*"
      ],
      "@landmap/ui": [
        "../packages/ui/src/index.ts"
      ],
      "@landmap/config": [
        "../config/src/env.ts"
      ],
      "@landmap/*": [
        "../*/src/index.ts"
      ]
    },
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "noEmit": true,
    "incremental": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "src/**/*",
    "next-env.d.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    ".next"
  ]
}
