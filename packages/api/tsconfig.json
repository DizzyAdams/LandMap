{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "paths": {
      "@landmap/llm": ["./node_modules/@landmap/llm"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
