{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "paths": {
      "@landmap/config": ["../config/src/index.ts"],
      "@landmap/db": ["../db/src/index.ts"],
      "@landmap/geo": ["../geo/src/index.ts"],
      "@landmap/integrations": ["../integrations/src/index.ts"],
      "@landmap/invest": ["../invest/src/index.ts"],
      "@landmap/llm": ["../llm/src/index.ts"],
      "@landmap/llm/*": ["../llm/src/*"],
      "@landmap/sales": ["../sales/src/index.ts"],
      "@landmap/sales/*": ["../sales/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
